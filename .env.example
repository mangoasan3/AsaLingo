# ─────────────────────────────────────────────────────────────────────────────
# AsaLingo environment configuration
#
# IMPORTANT: Copy this file to .env and fill in real values.
#            Never commit .env or any file containing real secrets to git.
#            Rotate any key that was accidentally exposed.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (MongoDB) ───────────────────────────────────────────────────────
# Local without Docker:
MONGODB_URI=mongodb://localhost:27017/asalingo
# With Docker Compose, the backend uses: mongodb://mongodb:27017/asalingo

# ─── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── AI (DeepSeek) ────────────────────────────────────────────────────────────
# Get your key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:4000/api
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# ─── Rate Limiting (optional overrides) ───────────────────────────────────────
# AUTH_LOGIN_RATE_LIMIT_MAX=8
# AUTH_REGISTER_RATE_LIMIT_MAX=5
# AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX=5
# AUTH_RESET_PASSWORD_RATE_LIMIT_MAX=5
# RATE_LIMIT_REDIS_URL=redis://localhost:6379
